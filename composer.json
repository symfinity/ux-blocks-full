{
    "name": "symfinity/ux-blocks-full",
    "description": "Symfinity UX Blocks full catalog metapackage — core + extended + interactive official roles",
    "license": "MIT",
    "type": "metapackage",
    "require": {
        "symfinity/ux-blocks-core": "@dev",
        "symfinity/ux-blocks-extended": "@dev",
        "symfinity/ux-blocks-interactive": "@dev"
    },
    "suggest": {
        "symfinity/ux-blocks-live": "Optional LiveComponent catalog tier",
        "symfinity/ux-blocks-marketing": "Optional landing section library",
        "symfinity/ux-blocks-ecommerce": "Optional shop section library"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../ux-blocks-core",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "../ux-blocks-extended",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "../ux-blocks-interactive",
            "options": { "symlink": true }
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Symfinity\\UxBlocksFull\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit -c phpunit.xml.dist"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "version": "0.1.0-dev",
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    }
}
